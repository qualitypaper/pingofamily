{
  "compilerOptions": {
    "target": "es6",
    "baseUrl": "src",
    "paths": {
      "app/*": [
        "./app/*"
      ],
      "assets/*": [
        "./assets/*"
      ],
      "components/*": [
        "./components/*"
      ],
      "store/*": [
        "./store/*"
      ],
      "utils/*": [
        "./utils/*"
      ],
      "hooks/*": [
        "./hooks/*"
      ],
      "pages/*": [
        "./pages/*"
      ],
      "types/*": [
        "./types/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "downlevelIteration": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "typeRoots": [
      "./typings",
      "./node_modules/@types"
    ],
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src",
    "src/custom.d.ts",
    "src/store/training/trainingTypes.d.ts"
  ]
}